          "processorEnabled": false,
          "gainEvents": []
        },
        {
          "name": "Faust laser lead",
          "language": "faust",
          "sync": true,
          "tempo": 122,
          "timeSigNumerator": 4,
          "timeSigDenominator": 4,
          "phase": 0,
          "gain": 0.38,
          "muted": false,
          "soloed": false,
          "code": "import(\"stdfaust.lib\");\nfreq = hslider(\"hostFreq\", 330, 40, 4000, 0.01);\ngain = hslider(\"hostGain\", 0.045, 0, 0.15, 0.001);\nstateGain = hslider(\"hostStateGain\", 1, 0, 1, 0.001);\ntrackGain = hslider(\"hostTrackGain\", 1, 0, 1, 0.001);\nlead = os.osc(freq * 2) * 0.62 + os.osc(freq * 3) * 0.22 + os.osc(freq * 4.01) * 0.12;\nprocess = lead * gain * stateGain * trackGain <: _, _;",
          "processorLanguage": "chuck",
          "processorCode": "",
          "processorEnabled": false,
          "gainEvents": []
        },
        {
          "name": "Csound pocket pluck",
          "language": "csound",
          "sync": true,
          "tempo": 122,
          "timeSigNumerator": 4,
          "timeSigDenominator": 4,
          "phase": 0,
          "gain": 0.36,
          "muted": false,
          "soloed": false,
          "code": "giSine ftgen 1, 0, 4096, 10, 1\ninstr 1\n    kfreq chnget \"hostFreq\"\n    kgain chnget \"hostGain\"\n    kstate chnget \"hostStateGain\"\n    ktrack chnget \"hostTrackGain\"\n    kbeat chnget \"hostStateBeat\"\n    kphase = frac(kbeat * 4)\n    kenv = exp(-kphase * 7)\n    a1 vco2 kgain * 0.10 * kenv * kstate * ktrack, kfreq * 1.5, 2\n    a2 oscili kgain * 0.07 * kenv * kstate * ktrack, kfreq * 3.0, giSine\n    outs a1 + a2, a1 - a2\nendin",
          "processorLanguage": "chuck",
          "processorCode": "",
          "processorEnabled": false,
          "gainEvents": []
        },
