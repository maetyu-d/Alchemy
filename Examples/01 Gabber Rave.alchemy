          "muted": false,
          "soloed": false,
          "code": "SinOsc k => Gain g => dac;\nwhile (true) { 45 => k.freq; 0.56 * hostGain * hostStateGain * hostTrackGain => g.gain; 38::ms => now; 0 => g.gain; 76::ms => now; }",
          "gainEvents": []
