  "chuckScoreScript": "score.clear();\ntempo(84);\nmeter(5, 4);\nstate.add(\"Glass\", 24, 10);\ntrack.add(1, \"slow fifths\", \"chuck\");\ntrack.gain(1, 1, 0.26);\ntrack.add(1, \"breath shimmer\", \"chuck\");\ntrack.gain(1, 2, 0.22);\ntrack.add(1, \"csound glint\", \"csound\");\ntrack.gain(1, 3, 0.20);\nstate.add(\"Low Cloud\", 20, 12);\ntrack.add(2, \"low bloom\", \"chuck\");\ntrack.gain(2, 1, 0.24);\ntrack.add(2, \"slow answer\", \"chuck\");\ntrack.gain(2, 2, 0.18);\ntrack.add(2, \"quiet sub\", \"rtcmix\");\ntrack.gain(2, 3, 0.26);\nstate.add(\"Bright Return\", 28, 10);\ntrack.add(3, \"bright pins\", \"csound\");\ntrack.gain(3, 1, 0.22);\ntrack.add(3, \"wide fifth\", \"supercollider\");\ntrack.gain(3, 2, 0.25);\ntrack.add(3, \"soft pulse\", \"chuck\");\ntrack.gain(3, 3, 0.21);\nstate.connect(1, 2, 45);\nstate.connect(1, 3, 55);\nstate.connect(2, 3, 1);\nplay();",
