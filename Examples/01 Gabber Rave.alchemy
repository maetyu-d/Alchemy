          "code": "SinOsc b => Gain g => dac;\n[36, 36, 36, 43, 36, 48, 36, 34] @=> int notes[];\n0 => int i;\nwhile (true) {\n    Std.mtof(notes[i % notes.cap()]) => b.freq;\n    0.38 * hostGain * hostStateGain * hostTrackGain => g.gain;\n    58::ms => now;\n    0 => g.gain;\n    (i % 3 == 0 ? 96::ms : 42::ms) => now;\n    i++;\n}",
