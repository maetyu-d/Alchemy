          "code": "bus_config(\"WAVETABLE\", \"out 0\")\nfreq = makeconnection(\"inlet\", 1, 55)\ngain = makeconnection(\"inlet\", 2, 0.035)\nstategain = makeconnection(\"inlet\", 5, 1)\ntrackgain = makeconnection(\"inlet\", 14, 1)\nwave = maketable(\"wave\", 4096, \"sine\", 1, 0.22)\nWAVETABLE(0, 3600, gain * stategain * trackgain * 32767, 55, 0.5, wave)",
