  "chuckScoreScript": "score.clear();\ntempo(210);\nmeter(4, 4);\nstate.add(\"60Hz Gabber Rave 1995\", 84, 0);\ntrack.add(1, \"Exact SC gabber rave\", \"supercollider-score\");\ntrack.gain(1, 1, 1.00);\nstate.add(\"Hoover Lift\", 32, 4);\ntrack.add(2, \"SC gabber hoover\", \"supercollider\");\ntrack.gain(2, 1, 0.34);\ntrack.add(2, \"ChucK detuned hoover\", \"chuck\");\ntrack.gain(2, 2, 0.30);\ntrack.add(2, \"Syncopated heavy bass\", \"chuck\");\ntrack.gain(2, 3, 0.36);\ntrack.add(2, \"ChucK siren pin\", \"chuck\");\ntrack.gain(2, 4, 0.22);\nstate.add(\"Rumble Break\", 48, 4);\ntrack.add(3, \"RTcmix 60Hz rumble\", \"rtcmix\");\ntrack.gain(3, 1, 0.44);\ntrack.add(3, \"ChucK pedal hammer\", \"chuck\");\ntrack.gain(3, 2, 0.28);\ntrack.add(3, \"ChucK broken kick\", \"chuck\");\ntrack.gain(3, 3, 0.38);\ntrack.add(3, \"ChucK low hoover\", \"chuck\");\ntrack.gain(3, 4, 0.28);\nstate.add(\"Strobe Coda\", 24, 2);\ntrack.add(4, \"ChucK coda stab\", \"chuck\");\ntrack.gain(4, 1, 0.40);\ntrack.add(4, \"ChucK coda hoover\", \"chuck\");\ntrack.gain(4, 2, 0.34);\ntrack.add(4, \"Csound closing rave\", \"csound\");\ntrack.gain(4, 3, 0.34);\ntrack.add(4, \"ChucK floor siren\", \"chuck\");\ntrack.gain(4, 4, 0.30);\nstate.connect(1, 2, 70);\nstate.connect(1, 3, 30);\nstate.connect(2, 3, 50);\nstate.connect(2, 4, 50);\nstate.connect(3, 4, 1);\nplay();",
