          "code": "SinOsc s => Gain g => dac;\n[196, 247, 294, 196, 330, 247, 220] @=> int notes[];\n0 => int i;\nwhile (true) {\n    notes[i % notes.cap()] => s.freq;\n    0.22 * hostGain * hostStateGain * hostTrackGain => g.gain;\n    75::ms => now;\n    0 => g.gain;\n    110::ms => now;\n    i++;\n}",
