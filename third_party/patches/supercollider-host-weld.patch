diff --git a/server/scsynth/SC_HostAudio.cpp b/server/scsynth/SC_HostAudio.cpp
new file mode 100644
index 0000000..ae3a1f4
--- /dev/null
+++ b/server/scsynth/SC_HostAudio.cpp
@@ -0,0 +1,156 @@
+/*
+    Host-pulled audio driver for embedded libscsynth use.
+    This backend does not open an audio device. The embedding host owns the
+    callback and advances scsynth by calling World_RenderHostAudio().
+*/
+
+#include "SC_CoreAudio.h"
+#include "SC_HiddenWorld.h"
+#include "SC_Prototypes.h"
+#include "SC_Time.hpp"
+#include "SC_WorldOptions.h"
+#include "SC_BoundsMacros.h"
+
+#include <algorithm>
+#include <cmath>
+#include <cstring>
+#include <stdexcept>
+
+int32 server_timeseed() {
+    return timeSeed();
+}
+
+int64 oscTimeNow() {
+    return OSCTime(getTime());
+}
+
+void initializeScheduler() {}
+
+namespace {
+class SC_HostAudioDriver final : public SC_AudioDriver {
+public:
+    explicit SC_HostAudioDriver(World* inWorld): SC_AudioDriver(inWorld) {}
+
+    bool Render(const float* input, float* output, int frames, int inputChannels, int outputChannels) {
+        if (output == nullptr || frames <= 0)
+            return false;
+
+        const int bufFrames = static_cast<int>(mWorld->mBufLength);
+        if (bufFrames <= 0 || frames % bufFrames != 0)
+            return false;
+
+        try {
+            mToEngine.Perform();
+            mOscPacketsToEngine.Perform();
+            mFromEngine.Perform();
+            mFromEngine.Free();
+
+            const int numBufs = frames / bufFrames;
+            float* inBuses = mWorld->mAudioBus + mWorld->mNumOutputs * bufFrames;
+            float* outBuses = mWorld->mAudioBus;
+            int32* inTouched = mWorld->mAudioBusTouched + mWorld->mNumOutputs;
+            int32* outTouched = mWorld->mAudioBusTouched;
+
+            const int minInputs = sc_min(inputChannels, static_cast<int>(mWorld->mNumInputs));
+            const int minOutputs = sc_min(outputChannels, static_cast<int>(mWorld->mNumOutputs));
+            const double oscToSamples = mOSCtoSamples;
+            int64 oscTime = mOSCbuftime;
+
+            std::memset(output, 0, sizeof(float) * static_cast<size_t>(frames) * static_cast<size_t>(outputChannels));
+
+            for (int buf = 0; buf < numBufs; ++buf, ++mWorld->mBufCounter) {
+                const int frameOffset = buf * bufFrames;
+                const int32 bufCounter = mWorld->mBufCounter;
+
+                if (input != nullptr && minInputs > 0) {
+                    int32* touched = inTouched;
+                    for (int channel = 0; channel < minInputs; ++channel) {
+                        float* dst = inBuses + channel * bufFrames;
+                        for (int frame = 0; frame < bufFrames; ++frame) {
+                            const float sample = input[(frameOffset + frame) * inputChannels + channel];
+                            *dst++ = std::isfinite(sample) ? sample : 0.0f;
+                        }
+                        *touched++ = bufCounter;
+                    }
+                }
+
+                const int64 nextTime = oscTime + mOSCincrement;
+                int64 schedTime;
+                while ((schedTime = mScheduler.NextTime()) <= nextTime) {
+                    const float diffTime = static_cast<float>(schedTime - oscTime) * static_cast<float>(oscToSamples) + 0.5f;
+                    const float diffTimeFloor = std::floor(diffTime);
+                    mWorld->mSampleOffset = static_cast<int>(diffTimeFloor);
+                    mWorld->mSubsampleOffset = diffTime - diffTimeFloor;
+
+                    if (mWorld->mSampleOffset < 0)
+                        mWorld->mSampleOffset = 0;
+                    else if (mWorld->mSampleOffset >= mWorld->mBufLength)
+                        mWorld->mSampleOffset = mWorld->mBufLength - 1;
+
+                    SC_ScheduledEvent event = mScheduler.Remove();
+                    event.Perform();
+                }
+
+                mWorld->mSampleOffset = 0;
+                mWorld->mSubsampleOffset = 0.0f;
+                World_Run(mWorld);
+
+                int32* touched = outTouched;
+                for (int channel = 0; channel < minOutputs; ++channel) {
+                    const float* src = outBuses + channel * bufFrames;
+                    if (*touched++ == bufCounter) {
+                        for (int frame = 0; frame < bufFrames; ++frame) {
+                            const float sample = src[frame];
+                            output[(frameOffset + frame) * outputChannels + channel] =
+                                std::isfinite(sample) ? sample : 0.0f;
+                        }
+                    }
+                }
+
+                oscTime = nextTime;
+                mOSCbuftime = nextTime;
+            }
+
+            mAudioSync.Signal();
+            return true;
+        } catch (const std::exception& exc) {
+            scprintf("SC_HostAudioDriver: exception in host render: %s\n", exc.what());
+        } catch (...) {
+            scprintf("SC_HostAudioDriver: unknown exception in host render\n");
+        }
+
+        return false;
+    }
+
+protected:
+    bool DriverSetup(int* outNumSamplesPerCallback, double* outSampleRate) override {
+        *outNumSamplesPerCallback = mPreferredHardwareBufferFrameSize > 0
+            ? static_cast<int>(mPreferredHardwareBufferFrameSize)
+            : static_cast<int>(mWorld->mBufLength);
+
+        *outSampleRate = mPreferredSampleRate > 0 ? static_cast<double>(mPreferredSampleRate) : 48000.0;
+        mHardwareBufferSize = static_cast<uint32>(*outNumSamplesPerCallback);
+        return true;
+    }
+
+    bool DriverStart() override { return true; }
+    bool DriverStop() override { return true; }
+};
+} // namespace
+
+SC_AudioDriver* SC_NewAudioDriver(World* inWorld) {
+    return new SC_HostAudioDriver(inWorld);
+}
+
+SCSYNTH_DLLEXPORT_C bool World_RenderHostAudio(World* inWorld, const float* inInterleavedInput,
+                                               float* outInterleavedOutput, int inFrames, int inInputChannels,
+                                               int inOutputChannels) {
+    if (inWorld == nullptr || inWorld->hw == nullptr || inWorld->hw->mAudioDriver == nullptr)
+        return false;
+
+    auto* driver = dynamic_cast<SC_HostAudioDriver*>(inWorld->hw->mAudioDriver);
+    if (driver == nullptr)
+        return false;
+
+    return driver->Render(inInterleavedInput, outInterleavedOutput, inFrames, inInputChannels, inOutputChannels);
+}
