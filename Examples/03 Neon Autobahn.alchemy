  "chuckScoreScript": "score.clear();\ntempo(122);\nmeter(4, 4);\nphase(0);\nstate.add(\"Autobahn Theme\", 32, 4);\ntrack.add(1, \"Motorik tick\", \"chuck\");\ntrack.gain(1, 1, 0.44);\ntrack.add(1, \"Neon lead\", \"chuck\");\ntrack.gain(1, 2, 0.50);\ntrack.add(1, \"Warm machine pad\", \"supercollider\");\ntrack.gain(1, 3, 0.42);\ntrack.add(1, \"Round octave bass\", \"chuck\");\ntrack.gain(1, 4, 0.42);\nstate.add(\"Computer Love\", 32, 5);\ntrack.add(2, \"Bell reply\", \"csound\");\ntrack.gain(2, 1, 0.42);\ntrack.add(2, \"Counter melody\", \"chuck\");\ntrack.gain(2, 2, 0.46);\ntrack.add(2, \"Vocoder choir\", \"supercollider\");\ntrack.gain(2, 3, 0.38);\ntrack.add(2, \"RTcmix electric bass\", \"rtcmix\");\ntrack.gain(2, 4, 0.34);\nstate.add(\"Pocket Calculator\", 24, 3);\ntrack.add(3, \"Click arpeggio\", \"chuck\");\ntrack.gain(3, 1, 0.42);\ntrack.add(3, \"Faust laser lead\", \"faust\");\ntrack.gain(3, 2, 0.38);\ntrack.add(3, \"Csound pocket pluck\", \"csound\");\ntrack.gain(3, 3, 0.36);\ntrack.add(3, \"Soft motorik bass\", \"chuck\");\ntrack.gain(3, 4, 0.34);\nstate.add(\"Trans Europe Coda\", 40, 6);\ntrack.add(4, \"Final melody\", \"chuck\");\ntrack.gain(4, 1, 0.50);\ntrack.add(4, \"Wide chord memory\", \"supercollider\");\ntrack.gain(4, 2, 0.44);\ntrack.add(4, \"Faust sparkle\", \"faust\");\ntrack.gain(4, 3, 0.34);\ntrack.add(4, \"Station bass\", \"chuck\");\ntrack.gain(4, 4, 0.36);\nstate.connect(1, 2, 65);\nstate.connect(1, 3, 35);\nstate.connect(2, 3, 45);\nstate.connect(2, 4, 55);\nstate.connect(3, 4, 1);\nplay();",
  "tempoMap": [
