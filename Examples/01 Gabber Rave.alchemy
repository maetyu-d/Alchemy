  "chuckScoreScript": "score.clear();\ntempo(210);\nmeter(4, 4);\nstate.add(\"Kick Room\", 32, 2);\ntrack.add(1, \"60Hz hammer\", \"chuck\");\ntrack.gain(1, 1, 0.86);\ntrack.add(1, \"hard edge\", \"csound\");\ntrack.gain(1, 2, 0.38);\nstate.add(\"Hoover Lift\", 32, 4);\ntrack.add(2, \"detuned hoover\", \"supercollider\");\ntrack.gain(2, 1, 0.42);\ntrack.add(2, \"sync bass\", \"chuck\");\ntrack.gain(2, 2, 0.50);\nstate.add(\"Rumble Break\", 48, 4);\ntrack.add(3, \"rtcmix rumble\", \"rtcmix\");\ntrack.gain(3, 1, 0.42);\ntrack.add(3, \"broken kick\", \"chuck\");\ntrack.gain(3, 2, 0.70);\nstate.add(\"Coda\", 24, 2);\ntrack.add(4, \"floor siren\", \"chuck\");\ntrack.gain(4, 1, 0.46);\nstate.connect(1, 2, 70);\nstate.connect(1, 3, 30);\nstate.connect(2, 3, 50);\nstate.connect(2, 4, 50);\nstate.connect(3, 4, 1);\nplay();",
