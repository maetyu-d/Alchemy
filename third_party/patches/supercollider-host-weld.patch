diff --git a/lang/LangSource/SC_WeldLangBridge.cpp b/lang/LangSource/SC_WeldLangBridge.cpp
new file mode 100644
index 0000000..6ed01b7
--- /dev/null
+++ b/lang/LangSource/SC_WeldLangBridge.cpp
@@ -0,0 +1,655 @@
+#include "SC_LanguageClient.h"
+#include "SC_LanguageConfig.hpp"
+
+#include <cctype>
+#include <cstdlib>
+#include <cstdio>
+#include <cstring>
+#include <mutex>
+#include <string>
+#include <vector>
+
+namespace {
+class WeldLanguageClient final : public SC_LanguageClient {
+public:
+    explicit WeldLanguageClient(const char* name): SC_LanguageClient(name != nullptr ? name : "weld-sclang") {}
+
+    void postText(const char* str, size_t len) override { append(str, len); }
+    void postFlush(const char* str, size_t len) override { append(str, len); }
+    void postError(const char* str, size_t len) override { append(str, len); }
+    void flush() override {}
+
+    void clearPostBuffer() { postBuffer.clear(); }
+    const std::string& getPostBuffer() const { return postBuffer; }
+
+private:
+    void append(const char* str, size_t len)
+    {
+        if (str != nullptr && len > 0)
+            postBuffer.append(str, len);
+    }
+
+    std::string postBuffer;
+};
+
+std::mutex& bridgeMutex()
+{
+    static auto* mutex = new std::mutex;
+    return *mutex;
+}
+
+SC_LanguageClient*& bridgeClient()
+{
+    static SC_LanguageClient* client = nullptr;
+    return client;
+}
+
+bool& bridgeCompiled()
+{
+    static bool compiled = false;
+    return compiled;
+}
+
+bool& bridgeShutdownRegistered()
+{
+    static bool registered = false;
+    return registered;
+}
+
+void setError(char* buffer, int bufferSize, const char* message)
+{
+    if (buffer == nullptr || bufferSize <= 0)
+        return;
+
+    std::snprintf(buffer, static_cast<size_t>(bufferSize), "%s", message != nullptr ? message : "");
+}
+
+std::string escapeSCString(const char* text)
+{
+    std::string result;
+    if (text == nullptr)
+        return result;
+
+    for (const char* p = text; *p != '\0'; ++p) {
+        if (*p == '\\' || *p == '"')
+            result.push_back('\\');
+        result.push_back(*p);
+    }
+
+    return result;
+}
+
+struct ScoreSourceRewrite {
+    std::string source;
+    std::string extractedSynthDefs;
+};
+
+bool startsWithAt(const std::string& text, size_t index, const char* token)
+{
+    return token != nullptr && text.compare(index, std::strlen(token), token) == 0;
+}
+
+size_t findMatchingDelimiter(const std::string& text, size_t openIndex)
+{
+    if (openIndex >= text.size())
+        return std::string::npos;
+
+    const char opener = text[openIndex];
+    const char closer = opener == '(' ? ')' : opener == '[' ? ']' : opener == '{' ? '}' : '\0';
+    if (closer == '\0')
+        return std::string::npos;
+
+    int depth = 0;
+    bool inString = false;
+    bool escaping = false;
+    bool inLineComment = false;
+    bool inBlockComment = false;
+
+    for (size_t i = openIndex; i < text.size(); ++i) {
+        const char c = text[i];
+        const char next = i + 1 < text.size() ? text[i + 1] : '\0';
+
+        if (inLineComment) {
+            if (c == '\n' || c == '\r')
+                inLineComment = false;
+            continue;
+        }
+
+        if (inBlockComment) {
+            if (c == '*' && next == '/') {
+                inBlockComment = false;
+                ++i;
+            }
+            continue;
+        }
+
+        if (inString) {
+            if (escaping) {
+                escaping = false;
+            } else if (c == '\\') {
+                escaping = true;
+            } else if (c == '"') {
+                inString = false;
+            }
+            continue;
+        }
+
+        if (c == '/' && next == '/') {
+            inLineComment = true;
+            ++i;
+            continue;
+        }
+
+        if (c == '/' && next == '*') {
+            inBlockComment = true;
+            ++i;
+            continue;
+        }
+
+        if (c == '"') {
+            inString = true;
+            continue;
+        }
+
+        if (c == '$') {
+            ++i;
+            continue;
+        }
+
+        if (c == opener) {
+            ++depth;
+        } else if (c == closer) {
+            --depth;
+            if (depth == 0)
+                return i;
+        }
+    }
+
+    return std::string::npos;
+}
+
+size_t skipWhitespace(const std::string& text, size_t index)
+{
+    while (index < text.size()) {
+        const auto c = static_cast<unsigned char>(text[index]);
+        if (c != ' ' && c != '\t' && c != '\n' && c != '\r')
+            break;
+
+        ++index;
+    }
+
+    return index;
+}
+
+size_t consumeOptionalMethodCall(const std::string& text, size_t index, const char* methodName)
+{
+    index = skipWhitespace(text, index);
+    const auto methodLength = std::strlen(methodName);
+    if (index >= text.size() || text[index] != '.' || text.compare(index + 1, methodLength, methodName) != 0)
+        return std::string::npos;
+
+    auto end = index + 1 + methodLength;
+    end = skipWhitespace(text, end);
+    if (end < text.size() && text[end] == '(') {
+        const auto close = findMatchingDelimiter(text, end);
+        if (close == std::string::npos)
+            return std::string::npos;
+        end = close + 1;
+    }
+
+    end = skipWhitespace(text, end);
+    if (end < text.size() && text[end] == ';')
+        ++end;
+
+    return end;
+}
+
+std::vector<std::string> extractAddedSynthDefs(std::string& source)
+{
+    std::vector<std::string> synthDefs;
+    std::string stripped;
+    stripped.reserve(source.size());
+
+    size_t cursor = 0;
+    while (cursor < source.size()) {
+        const auto start = source.find("SynthDef(", cursor);
+        if (start == std::string::npos) {
+            stripped.append(source, cursor, std::string::npos);
+            break;
+        }
+
+        const auto close = findMatchingDelimiter(source, start + std::strlen("SynthDef"));
+        if (close == std::string::npos) {
+            stripped.append(source, cursor, std::string::npos);
+            break;
+        }
+
+        const auto removeEnd = consumeOptionalMethodCall(source, close + 1, "add");
+        if (removeEnd == std::string::npos) {
+            stripped.append(source, cursor, close + 1 - cursor);
+            cursor = close + 1;
+            continue;
+        }
+
+        stripped.append(source, cursor, start - cursor);
+        synthDefs.push_back(source.substr(start, close + 1 - start));
+        cursor = removeEnd;
+    }
+
+    source = std::move(stripped);
+    return synthDefs;
+}
+
+void stripPatternPlayCalls(std::string& source)
+{
+    size_t cursor = 0;
+    while ((cursor = source.find(".play", cursor)) != std::string::npos) {
+        const auto previous = cursor > 0 ? source[cursor - 1] : '\0';
+        const auto next = cursor + 5 < source.size() ? source[cursor + 5] : '\0';
+        const auto previousIsIdentifier = std::isalnum(static_cast<unsigned char>(previous)) || previous == '_';
+        const auto nextIsIdentifier = std::isalnum(static_cast<unsigned char>(next)) || next == '_';
+
+        if (previousIsIdentifier || nextIsIdentifier) {
+            cursor += 5;
+            continue;
+        }
+
+        auto end = skipWhitespace(source, cursor + 5);
+        if (end < source.size() && source[end] == '(') {
+            const auto close = findMatchingDelimiter(source, end);
+            if (close == std::string::npos) {
+                cursor += 5;
+                continue;
+            }
+            end = close + 1;
+        }
+
+        source.erase(cursor, end - cursor);
+    }
+}
+
+std::string findLastPlayableTopLevelBlock(const std::string& source)
+{
+    std::string candidate;
+
+    for (size_t cursor = 0; cursor < source.size();) {
+        const auto open = source.find('(', cursor);
+        if (open == std::string::npos)
+            break;
+
+        const auto close = findMatchingDelimiter(source, open);
+        if (close == std::string::npos)
+            break;
+
+        const auto block = source.substr(open, close + 1 - open);
+        if (block.find("Ppar(") != std::string::npos
+            || block.find("Pbind(") != std::string::npos
+            || block.find("Ptpar(") != std::string::npos
+            || block.find("Pdef(") != std::string::npos
+            || block.find("Score(") != std::string::npos)
+        {
+            candidate = block;
+        }
+
+        cursor = close + 1;
+    }
+
+    return candidate;
+}
+
+ScoreSourceRewrite rewriteScoreSource(const char* source)
+{
+    ScoreSourceRewrite rewrite;
+    rewrite.source = source != nullptr ? source : "";
+
+    auto synthDefs = extractAddedSynthDefs(rewrite.source);
+    stripPatternPlayCalls(rewrite.source);
+
+    if (!synthDefs.empty()) {
+        const auto playableBlock = findLastPlayableTopLevelBlock(rewrite.source);
+        if (!playableBlock.empty())
+            rewrite.source = playableBlock;
+
+        rewrite.extractedSynthDefs = "[";
+        for (size_t i = 0; i < synthDefs.size(); ++i) {
+            if (i != 0)
+                rewrite.extractedSynthDefs += ", ";
+            rewrite.extractedSynthDefs += synthDefs[i];
+        }
+        rewrite.extractedSynthDefs += "]";
+    }
+
+    return rewrite;
+}
+}
+
+extern "C" __attribute__((visibility("default"))) void WeldSCLang_Shutdown();
+
+extern "C" __attribute__((visibility("default"))) bool WeldSCLang_Initialise(const char* runtimeDirectory,
+                                                                              char* errorBuffer,
+                                                                              int errorBufferSize)
+{
+    std::lock_guard<std::mutex> lock(bridgeMutex());
+
+    if (bridgeCompiled())
+        return true;
+
+    if (bridgeClient() == nullptr) {
+        bridgeClient() = new WeldLanguageClient("weld-sclang");
+        if (bridgeClient() == nullptr) {
+            setError(errorBuffer, errorBufferSize, "could not create embedded sclang client");
+            return false;
+        }
+
+        SC_LanguageClient::Options options;
+        if (runtimeDirectory != nullptr)
+            options.mRuntimeDir = runtimeDirectory;
+        options.mPort = 0;
+        bridgeClient()->initRuntime(options);
+    }
+
+    SC_LanguageConfig::defaultLibraryConfig(true);
+    if (runtimeDirectory != nullptr) {
+        std::string classLibraryPath = std::string(runtimeDirectory) + "/SCClassLibrary";
+        gLanguageConfig->addIncludedDirectory(classLibraryPath);
+    }
+
+    bridgeClient()->compileLibrary(true);
+    bridgeCompiled() = bridgeClient()->isLibraryCompiled();
+
+    if (!bridgeCompiled()) {
+        setError(errorBuffer, errorBufferSize, "embedded sclang class library did not compile");
+        return false;
+    }
+
+    if (!bridgeShutdownRegistered()) {
+        std::atexit(WeldSCLang_Shutdown);
+        bridgeShutdownRegistered() = true;
+    }
+
+    setError(errorBuffer, errorBufferSize, "");
+    return true;
+}
+
+extern "C" __attribute__((visibility("default"))) void WeldSCLang_Shutdown()
+{
+    std::lock_guard<std::mutex> lock(bridgeMutex());
+
+    if (bridgeClient() != nullptr) {
+        bridgeClient()->shutdownLibrary();
+        bridgeClient()->shutdownRuntime();
+        destroyLanguageClient(bridgeClient());
+        bridgeClient() = nullptr;
+    }
+
+    bridgeCompiled() = false;
+}
+
+extern "C" __attribute__((visibility("default"))) bool WeldSCLang_CompileSynthDef(const char* source,
+                                                                                   const char* outputPath,
+                                                                                   const char* synthName,
+                                                                                   char* errorBuffer,
+                                                                                   int errorBufferSize)
+{
+    std::lock_guard<std::mutex> lock(bridgeMutex());
+
+    if (bridgeClient() == nullptr || !bridgeCompiled()) {
+        setError(errorBuffer, errorBufferSize, "embedded sclang is not initialised");
+        return false;
+    }
+
+    if (source == nullptr || outputPath == nullptr || synthName == nullptr) {
+        setError(errorBuffer, errorBufferSize, "missing SuperCollider compile input");
+        return false;
+    }
+
+    std::remove(outputPath);
+    static_cast<WeldLanguageClient*>(bridgeClient())->clearPostBuffer();
+
+    const auto escapedSource = escapeSCString(source);
+    const auto escapedOutputPath = escapeSCString(outputPath);
+    const auto escapedSynthName = escapeSCString(synthName);
+
+    const std::string command =
+        "var weldSource = \"" + escapedSource + "\";\n"
+        "var weldPath = \"" + escapedOutputPath + "\";\n"
+        "var weldName = \"" + escapedSynthName + "\".asSymbol;\n"
+        "var weldCompiled, weldDef, weldFile;\n"
+        "weldCompiled = thisProcess.interpreter.compile(weldSource).value;\n"
+        "if (weldCompiled.isKindOf(SynthDef)) {\n"
+        "    weldDef = weldCompiled;\n"
+        "} {\n"
+        "    if (weldCompiled.isKindOf(Function)) {\n"
+        "        weldDef = SynthDef(weldName, { |out = 0|\n"
+        "            var weldControls, weldSignal;\n"
+        "            weldControls = SharedIn.kr(0, 18);\n"
+        "            weldSignal = weldCompiled.valueArray(weldControls);\n"
+        "            Out.ar(out, weldSignal.asArray.extend(2, weldSignal));\n"
+        "        });\n"
+        "    } {\n"
+        "        Error(\"Weld SuperCollider source must evaluate to a SynthDef or Function\").throw;\n"
+        "    };\n"
+        "};\n"
+        "weldFile = File(weldPath, \"w\");\n"
+        "protect { weldDef.asArray.writeDef(weldFile); } { weldFile.close; };\n";
+
+    bridgeClient()->setCmdLine(command.c_str(), command.size());
+    bridgeClient()->interpretCmdLine();
+    bridgeClient()->flush();
+
+    FILE* file = std::fopen(outputPath, "rb");
+    if (file == nullptr) {
+        const auto& postBuffer = static_cast<WeldLanguageClient*>(bridgeClient())->getPostBuffer();
+        if (!postBuffer.empty())
+            setError(errorBuffer, errorBufferSize, postBuffer.c_str());
+        else
+            setError(errorBuffer, errorBufferSize, "embedded sclang did not produce a SynthDef");
+        return false;
+    }
+
+    std::fclose(file);
+    setError(errorBuffer, errorBufferSize, "");
+    return true;
+}
+
+extern "C" __attribute__((visibility("default"))) bool WeldSCLang_CompileScore(const char* source,
+                                                                                const char* outputPath,
+                                                                                double durationSeconds,
+                                                                                double tempo,
+                                                                                char* errorBuffer,
+                                                                                int errorBufferSize)
+{
+    std::lock_guard<std::mutex> lock(bridgeMutex());
+
+    if (bridgeClient() == nullptr || !bridgeCompiled()) {
+        setError(errorBuffer, errorBufferSize, "embedded sclang is not initialised");
+        return false;
+    }
+
+    if (source == nullptr || outputPath == nullptr) {
+        setError(errorBuffer, errorBufferSize, "missing SuperCollider score compile input");
+        return false;
+    }
+
+    std::remove(outputPath);
+    static_cast<WeldLanguageClient*>(bridgeClient())->clearPostBuffer();
+
+    const auto rewritten = rewriteScoreSource(source);
+    const auto escapedSource = escapeSCString(rewritten.source.c_str());
+    const auto escapedExtractedSynthDefs = escapeSCString(rewritten.extractedSynthDefs.c_str());
+    const auto escapedOutputPath = escapeSCString(outputPath);
+
+    const std::string command =
+        "var weldSource = \"" + escapedSource + "\";\n"
+        "var weldExtractedSynthDefsSource = \"" + escapedExtractedSynthDefs + "\";\n"
+        "var weldPath = \"" + escapedOutputPath + "\";\n"
+        "var weldDurationBeats = " + std::to_string(durationSeconds) + ";\n"
+        "var weldTempo = " + std::to_string(tempo) + ";\n"
+        R"SC(
+var weldCompiled, weldPattern, weldDefs, weldExtractedDefs, weldFile, weldWriteMsg, weldStream, weldEvent, weldBeat, weldNode;
+var weldLoopBeats, weldWritePatternEvent, weldValueAt, weldAsArray, weldIsScalar, weldIncludeKey, weldDefaultDef;
+weldCompiled = thisProcess.interpreter.compile(weldSource).value;
+if (weldCompiled.isKindOf(Function)) { weldCompiled = weldCompiled.value; };
+weldExtractedDefs = nil;
+if (weldExtractedSynthDefsSource.notNil and: { weldExtractedSynthDefsSource.size > 0 }) {
+    weldExtractedDefs = thisProcess.interpreter.compile(weldExtractedSynthDefsSource).value;
+};
+weldDefs = nil;
+weldLoopBeats = weldDurationBeats;
+if (weldCompiled.isKindOf(Dictionary)) {
+    weldDefs = weldCompiled.at(\synthDefs) ? weldCompiled.at(\defs);
+    weldPattern = weldCompiled.at(\pattern) ? weldCompiled.at(\score) ? weldCompiled.at(\event);
+    weldLoopBeats = weldCompiled.at(\loopBeats) ? weldCompiled.at(\durationBeats) ? weldCompiled.at(\duration) ? weldLoopBeats;
+    weldTempo = weldCompiled.at(\tempo) ? weldTempo;
+    if (weldDefs.isNil) { weldDefs = weldExtractedDefs; };
+} {
+    weldPattern = weldCompiled;
+    weldDefs = weldExtractedDefs;
+};
+if (weldLoopBeats.isNumber.not or: { weldLoopBeats <= 0 }) { weldLoopBeats = 64.0; };
+if (weldTempo.isNumber.not or: { weldTempo <= 0 }) { weldTempo = 1.0; };
+weldFile = File(weldPath, "w");
+if (weldFile.isOpen.not) { Error("could not open Weld score output file").throw; };
+weldWriteMsg = { |beat, msg|
+    var osc = msg.asRawOSC;
+    weldFile.putString(beat.asString ++ "\t");
+    osc.do { |byte, index|
+        if (index > 0) { weldFile.putChar($,); };
+        weldFile.putString(byte.asInteger.asString);
+    };
+    weldFile.nl;
+};
+weldAsArray = { |value| if (value.isArray) { value } { [value] } };
+weldValueAt = { |value, index|
+    if (value.isArray) { value.wrapAt(index) } { value }
+};
+weldIsScalar = { |value| value.isNumber or: { value.isString or: { value.isKindOf(Symbol) } } };
+weldIncludeKey = { |key|
+    #[instrument, synthDefName, dur, delta, sustain, legato, stretch, type, isRest, server,
+      group, addAction, timingOffset, lag, latency, callback, sendGate, hasGate, id,
+      msgFunc, defaultMsgFunc, schedBundle, schedBundleArray, updatePmono, isPlaying,
+      freq, detunedFreq, midinote, note, degree, scale, octave, root, mtranspose,
+      gtranspose, ctranspose, harmonic, detune, amp, db, pan, out, strum,
+      strumEndsTogether].includes(key).not
+};
+weldDefaultDef = SynthDef(\default, { |out = 0, freq = 440, amp = 0.1, pan = 0, gate = 1|
+    var env = Linen.kr(gate, 0.01, 0.7, 0.3, doneAction: 2);
+    OffsetOut.ar(out, Pan2.ar(SinOsc.ar(freq) * env, pan, amp));
+});
+weldWritePatternEvent = { |event, beat|
+    var delta, eventType, instrument, freqs, amps, pans, outs, sustains, timingOffsets, lags;
+    var strum, count, addAction, group, sendGate, reverseOrder;
+    if (event.parent.isNil) { event.parent = Event.default.parent; };
+    delta = event.delta ? event.at(\dur) ? 1.0;
+    eventType = event.at(\type) ? \note;
+    if ((event.isRest or: { eventType == \rest })
+        or: { #[note, grain, monoNote, monoSet].includes(eventType).not }) {
+        delta
+    } {
+        instrument = event.use { ~synthDefName.valueEnvir } ? event.at(\instrument) ? \default;
+        freqs = weldAsArray.value(event.use { ~detunedFreq.value });
+        amps = weldAsArray.value(event.use { ~amp.value });
+        pans = weldAsArray.value(event.at(\pan) ? 0.0);
+        outs = weldAsArray.value(event.at(\out) ? 0);
+        sustains = weldAsArray.value(event.use { ~sustain.value });
+        timingOffsets = weldAsArray.value(event.at(\timingOffset) ? 0.0);
+        lags = weldAsArray.value(event.at(\lag) ? 0.0);
+        strum = event.at(\strum) ? 0.0;
+        addAction = Node.actionNumberFor(event.at(\addAction) ? \head);
+        group = event.at(\group);
+        if (group.isNumber.not) { group = 1; };
+        sendGate = event.at(\sendGate) ? true;
+        count = [freqs.size, amps.size, pans.size, outs.size, sustains.size, timingOffsets.size, lags.size].maxItem;
+        count = count.max(1);
+        reverseOrder = strum < 0;
+        count.do { |voiceIndex|
+            var index = if (reverseOrder) { count - 1 - voiceIndex } { voiceIndex };
+            var node = weldNode;
+            var eventBeat = beat + weldValueAt.value(timingOffsets, index) + weldValueAt.value(lags, index) + (voiceIndex * strum.abs);
+            var sustain = weldValueAt.value(sustains, index);
+            var msg = [\s_new, instrument, node, addAction, group,
+                       "freq", weldValueAt.value(freqs, index),
+                       "amp", weldValueAt.value(amps, index),
+                       "pan", weldValueAt.value(pans, index),
+                       "out", weldValueAt.value(outs, index)];
+            event.keysValuesDo { |key, value|
+                var controlValue = weldValueAt.value(value, index);
+                if (weldIncludeKey.value(key) and: { weldIsScalar.value(controlValue) }) {
+                    msg = msg.add(key.asString).add(controlValue);
+                };
+            };
+            weldWriteMsg.value(eventBeat, msg);
+            if (sendGate and: { sustain.notNil and: { sustain.isNumber } }) {
+                weldWriteMsg.value(eventBeat + sustain.max(0.0), [\n_set, node, "gate", 0]);
+            };
+            weldNode = weldNode + 1;
+        };
+        delta
+    };
+};
+protect {
+    weldFile.putString("#loopBeats\t" ++ weldLoopBeats.asString); weldFile.nl;
+    weldWriteMsg.value(-2.0, [\g_new, 1, 0, 0]);
+    weldWriteMsg.value(-1.5, [\d_recv, weldDefaultDef.asBytes]);
+    if (weldDefs.notNil) {
+        weldDefs.asArray.do { |def|
+            if (def.isKindOf(SynthDef).not) { Error("synthDefs entries must be SynthDef objects").throw; };
+            weldWriteMsg.value(-1.0, [\d_recv, def.asBytes]);
+        };
+    };
+    if (weldPattern.isKindOf(Score)) {
+        weldPattern.score.do { |item|
+            item.copyToEnd(1).do { |msg| weldWriteMsg.value(item[0] * weldTempo, msg) };
+        };
+    } {
+        if (weldPattern.isKindOf(Event)) { weldPattern = Pseq([weldPattern]); };
+        if (weldPattern.isKindOf(Pattern).not) {
