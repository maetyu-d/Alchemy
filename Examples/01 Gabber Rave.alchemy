        {"name": "60Hz hammer", "language": "chuck", "sync": true, "tempo": 210, "timeSigNumerator": 4, "timeSigDenominator": 4, "phase": 0, "gain": 0.86, "muted": false, "soloed": false, "code": "SinOsc s => Gain g => dac;\nwhile (true) {\n    60 => s.freq;\n    0.85 => g.gain;\n    35::ms => now;\n    0 => g.gain;\n    80::ms => now;\n}", "gainEvents": []},
