  "states": [
    {
      "name": "Autobahn Theme",
      "durationBeats": 32,
      "tailBeats": 4,
      "canvasX": 80,
      "canvasY": 160,
      "transitions": [
        {
          "targetStateIndex": 1,
          "weight": 65
        },
        {
          "targetStateIndex": 2,
          "weight": 35
        }
      ],
      "tracks": [
        {
          "name": "Motorik tick",
          "language": "chuck",
          "sync": true,
          "tempo": 122,
          "timeSigNumerator": 4,
          "timeSigDenominator": 4,
          "phase": 0,
          "gain": 0.44,
          "muted": false,
          "soloed": false,
          "code": "// soft motorik ticks\nNoise tick => HPF hp => Gain tickGain => dac;\nSinOsc kick => Gain kickGain => dac;\n6500 => hp.freq;\nwhile (true) {\n    Math.floor(hostStateBeat * 4.0) $ int => int step;\n    hostStateBeat * 4.0 - Math.floor(hostStateBeat * 4.0) => float phase;\n    Math.exp(-phase * 42.0) => float snap;\n    (step % 4 == 0 ? Math.exp(-phase * 12.0) : 0.0) => float thump;\n    58.0 + thump * 32.0 => kick.freq;\n    snap * Math.max(0.0, Math.min(hostGain, 0.035)) * hostStateGain * hostTrackGain => tickGain.gain;\n    thump * Math.max(0.0, Math.min(hostGain, 0.14)) * hostStateGain * hostTrackGain => kickGain.gain;\n    1::samp => now;\n}",
          "processorLanguage": "chuck",
          "processorCode": "",
          "processorEnabled": false,
          "gainEvents": []
        },
        {
          "name": "Neon lead",
          "language": "chuck",
          "sync": true,
          "tempo": 122,
          "timeSigNumerator": 4,
          "timeSigDenominator": 4,
          "phase": 0,
          "gain": 0.5,
          "muted": false,
          "soloed": false,
          "code": "// Autobahn lead: bright eighth-note melody\nTriOsc lead => Gain leadGain => dac;\nSinOsc shine => Gain shineGain => dac;\n[64, 66, 68, 71, 73, 71, 68, 66, 64, 68, 71, 76, 75, 71, 68, 66] @=> int notes[];\nwhile (true) {\n    Math.floor(hostStateBeat * 2.0) $ int => int step;\n    hostStateBeat * 2.0 - Math.floor(hostStateBeat * 2.0) => float phase;\n    Std.mtof(notes[step % notes.cap()]) => float f;\n    f => lead.freq;\n    f * 2.01 => shine.freq;\n    Math.exp(-phase * 3.0) * (0.62 + 0.38 * Math.sin(hostGlobalBeat * 0.125 * 6.2831853)) => float env;\n    Math.max(0.0, Math.min(hostGain, 0.15)) * hostStateGain * hostTrackGain * env => leadGain.gain;\n    Math.max(0.0, Math.min(hostGain, 0.06)) * hostStateGain * hostTrackGain * env => shineGain.gain;\n    1::samp => now;\n}",
          "processorLanguage": "chuck",
          "processorCode": "",
          "processorEnabled": false,
          "gainEvents": []
        },
        {
          "name": "Warm machine pad",
          "language": "supercollider",
          "sync": true,
          "tempo": 122,
          "timeSigNumerator": 4,
          "timeSigDenominator": 4,
          "phase": 0,
          "gain": 0.42,
          "muted": false,
          "soloed": false,
          "code": "{ |freq = 220, gain = 0.08, blend = 0.5, stateGate = 1, stateGain = 1, tempoBpm = 122,\n   stateBeat = 0, globalBeat = 0, timeSigNumerator = 4, timeSigDenominator = 4,\n   barBeat = 0, barPhase = 0, phaseRotation = 0, trackGain = 1, trackTempoBpm = 122,\n   trackTimeSigNumerator = 4, trackTimeSigDenominator = 4, trackPhaseRotation = 0|\n    var root = freq.max(80) * 0.5;\n    var sweep = SinOsc.kr(0.07).range(600, 2600);\n    var slow = SinOsc.kr(0.11, [0, 1.2]).range(0.98, 1.02);\n    var chord = SinOsc.ar(root * [1, 1.25, 1.5, 1.875, 2.5] * slow[0], 0, [0.20, 0.15, 0.13, 0.10, 0.08]).sum;\n    var shimmer = Pulse.ar(root * [4, 5.01] * slow[1], 0.45).sum * 0.035;\n    LPF.ar((chord + shimmer).tanh, sweep).dup * gain.min(0.12) * stateGain * trackGain\n}",
          "processorLanguage": "chuck",
          "processorCode": "",
          "processorEnabled": false,
          "gainEvents": []
        },
        {
          "name": "Round octave bass",
          "language": "chuck",
          "sync": true,
          "tempo": 122,
          "timeSigNumerator": 4,
          "timeSigDenominator": 4,
          "phase": 0,
          "gain": 0.42,
          "muted": false,
          "soloed": false,
          "code": "// rounded motorik octave bass\nSinOsc sub => Gain subGain => dac;\nSawOsc edge => Gain edgeGain => dac;\n[40, 40, 47, 40, 52, 47, 45, 47, 40, 43, 47, 52, 55, 52, 47, 43] @=> int bass[];\nwhile (true) {\n    Math.floor(hostStateBeat * 2.0) $ int => int step;\n    hostStateBeat * 2.0 - Math.floor(hostStateBeat * 2.0) => float phase;\n    Std.mtof(bass[step % bass.cap()]) => float f;\n    f => sub.freq;\n    f * 2.0 => edge.freq;\n    Math.exp(-phase * 5.4) => float env;\n    Math.max(0.0, Math.min(hostGain, 0.18)) * hostStateGain * hostTrackGain * (0.30 + env * 0.85) => subGain.gain;\n    Math.max(0.0, Math.min(hostGain, 0.055)) * hostStateGain * hostTrackGain * env => edgeGain.gain;\n    1::samp => now;\n}",
          "processorLanguage": "chuck",
          "processorCode": "",
          "processorEnabled": false,
          "gainEvents": []
        }
      ]
    },
    {
      "name": "Computer Love",
      "durationBeats": 32,
      "tailBeats": 5,
      "canvasX": 340,
      "canvasY": 70,
      "transitions": [
        {
          "targetStateIndex": 2,
          "weight": 45
        },
        {
          "targetStateIndex": 3,
