          "name": "SC gabber hoover",
          "language": "supercollider",
          "sync": true,
          "tempo": 210,
          "timeSigNumerator": 4,
          "timeSigDenominator": 4,
          "phase": 0,
          "gain": 0.34,
          "muted": false,
          "soloed": false,
          "code": "{ |freq = 440, gain = 0.1, blend = 0.5| Splay.ar(Saw.ar(freq * [0.495, 0.5, 0.997, 1.003]) * gain * 0.45).tanh }",
          "gainEvents": []
        },
        {
          "name": "ChucK detuned hoover",
          "language": "chuck",
          "sync": true,
          "tempo": 210,
          "timeSigNumerator": 4,
          "timeSigDenominator": 4,
          "phase": 0,
          "gain": 0.3,
          "muted": false,
          "soloed": false,
          "code": "SawOsc a => Gain mix => dac;\nSawOsc b => mix;\nwhile (true) {\n    hostFreq * 0.5 => a.freq;\n    hostFreq * 0.503 => b.freq;\n    0.20 * hostGain * hostStateGain * hostTrackGain => mix.gain;\n    1::sample => now;\n}",
          "gainEvents": []
        },
        {
          "name": "Syncopated heavy bass",
          "language": "chuck",
          "sync": true,
