      ],
      "tracks": [
        {
          "name": "ChucK 60Hz gabber kick",
          "language": "chuck",
          "sync": true,
          "tempo": 210,
          "timeSigNumerator": 4,
          "timeSigDenominator": 4,
          "phase": 0,
          "gain": 0.5,
          "muted": false,
          "soloed": false,
          "code": "SinOsc k => Gain g => dac;\nwhile (true) {\n    60 => k.freq;\n    0.82 * hostGain * hostStateGain * hostTrackGain => g.gain;\n    32::ms => now;\n    0 => g.gain;\n    82::ms => now;\n}",
          "gainEvents": []
        },
        {
          "name": "Offbeat hoover stab",
          "language": "chuck",
          "sync": true,
          "tempo": 210,
          "timeSigNumerator": 4,
          "timeSigDenominator": 4,
          "phase": 0,
          "gain": 0.36,
          "muted": false,
          "soloed": false,
          "code": "SawOsc a => Gain mix => dac;\nSawOsc b => mix;\n0.22 => mix.gain;\nwhile (true) {\n    hostFreq * 1.5 => a.freq;\n    hostFreq * 1.505 => b.freq;\n    55::ms => now;\n    0.02 => mix.gain;\n    95::ms => now;\n    0.22 * hostGain * hostStateGain * hostTrackGain => mix.gain;\n}",
          "gainEvents": []
        },
        {
          "name": "Csound hard edge",
          "language": "csound",
          "sync": true,
          "tempo": 210,
          "timeSigNumerator": 4,
          "timeSigDenominator": 4,
          "phase": 0,
          "gain": 0.3,
          "muted": false,
          "soloed": false,
          "code": "giSine ftgen 1, 0, 4096, 10, 1\ninstr 1\n kfreq chnget \"hostFreq\"\n kgain chnget \"hostGain\"\n a1 oscili kgain * 0.28, kfreq * 5, giSine\n a2 tanh(a1 * 7)\n outs a2, a2\nendin",
          "gainEvents": []
        },
        {
          "name": "Sub pressure",
          "language": "chuck",
          "sync": true,
          "tempo": 210,
          "timeSigNumerator": 4,
          "timeSigDenominator": 4,
          "phase": 0,
          "gain": 0.34,
          "muted": false,
          "soloed": false,
          "code": "SinOsc b => Gain g => dac;\n[36, 36, 43, 36, 48, 36, 34, 36] @=> int notes[];\n0 => int i;\nwhile (true) {\n    Std.mtof(notes[i % notes.cap()]) => b.freq;\n    0.32 * hostGain * hostStateGain * hostTrackGain => g.gain;\n    70::ms => now;\n    0 => g.gain;\n    45::ms => now;\n    i++;\n}",
          "gainEvents": []
        }
      ]
    },
    {
      "name": "Hoover Lift",
      "durationBeats": 32,
      "tailBeats": 4,
