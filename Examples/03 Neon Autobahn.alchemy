        }
      ],
      "tracks": [
        {
          "name": "Bell reply",
          "language": "csound",
          "sync": true,
          "tempo": 122,
          "timeSigNumerator": 4,
          "timeSigDenominator": 4,
          "phase": 0,
          "gain": 0.42,
          "muted": false,
          "soloed": false,
          "code": "giSine ftgen 1, 0, 4096, 10, 1\ninstr 1\n    kfreq chnget \"hostFreq\"\n    kgain chnget \"hostGain\"\n    kstate chnget \"hostStateGain\"\n    ktrack chnget \"hostTrackGain\"\n    kbeat chnget \"hostStateBeat\"\n    kphase = frac(kbeat * 2)\n    kenv = exp(-kphase * 5)\n    a1 oscili kgain * 0.20 * kenv * kstate * ktrack, kfreq * 2.0, giSine\n    a2 oscili kgain * 0.12 * kenv * kstate * ktrack, kfreq * 3.0, giSine\n    a3 oscili kgain * 0.08 * kenv * kstate * ktrack, kfreq * 5.0, giSine\n    outs a1 + a2, a1 + a3\nendin",
          "processorLanguage": "chuck",
          "processorCode": "",
          "processorEnabled": false,
          "gainEvents": []
        },
        {
          "name": "Counter melody",
          "language": "chuck",
          "sync": true,
          "tempo": 122,
          "timeSigNumerator": 4,
          "timeSigDenominator": 4,
          "phase": 0,
          "gain": 0.46,
          "muted": false,
          "soloed": false,
          "code": "// glassy counter-melody\nSinOsc a => Gain ag => dac;\nSinOsc b => Gain bg => dac;\n[76, 75, 71, 73, 68, 71, 66, 68, 80, 78, 76, 73, 75, 71, 68, 66] @=> int notes[];\nwhile (true) {\n    Math.floor((hostStateBeat + 0.5) * 1.0) $ int => int step;\n    (hostStateBeat + 0.5) - Math.floor(hostStateBeat + 0.5) => float phase;\n    Std.mtof(notes[step % notes.cap()]) => float f;\n    f => a.freq;\n    f * 1.502 => b.freq;\n    Math.exp(-phase * 2.2) => float env;\n    Math.max(0.0, Math.min(hostGain, 0.12)) * hostStateGain * hostTrackGain * env => ag.gain;\n    Math.max(0.0, Math.min(hostGain, 0.05)) * hostStateGain * hostTrackGain * env => bg.gain;\n    1::samp => now;\n}",
          "processorLanguage": "chuck",
          "processorCode": "",
          "processorEnabled": false,
          "gainEvents": []
        },
        {
          "name": "Vocoder choir",
          "language": "supercollider",
          "sync": true,
          "tempo": 122,
          "timeSigNumerator": 4,
          "timeSigDenominator": 4,
          "phase": 0,
          "gain": 0.38,
          "muted": false,
          "soloed": false,
          "code": "{ |freq = 220, gain = 0.07, blend = 0.5, stateGate = 1, stateGain = 1, tempoBpm = 122,\n   stateBeat = 0, globalBeat = 0, timeSigNumerator = 4, timeSigDenominator = 4,\n   barBeat = 0, barPhase = 0, phaseRotation = 0, trackGain = 1, trackTempoBpm = 122,\n   trackTimeSigNumerator = 4, trackTimeSigDenominator = 4, trackPhaseRotation = 0|\n    var pulse = LFPulse.kr(tempoBpm / 60 / 2, 0, 0.52).range(0.35, 1.0);\n    var sig = VarSaw.ar(freq.max(90) * [1, 1.5, 2, 2.5], 0, 0.42, [0.10, 0.08, 0.06, 0.05]).sum;\n    RLPF.ar(sig, SinOsc.kr(0.05).range(900, 3400), 0.28).dup * gain.min(0.10) * pulse * stateGain * trackGain\n}",
          "processorLanguage": "chuck",
          "processorCode": "",
          "processorEnabled": false,
          "gainEvents": []
        },
        {
          "name": "RTcmix electric bass",
          "language": "rtcmix",
          "sync": true,
          "tempo": 122,
          "timeSigNumerator": 4,
          "timeSigDenominator": 4,
          "phase": 0,
          "gain": 0.34,
          "muted": false,
          "soloed": false,
          "code": "bus_config(\"WAVETABLE\", \"out 0\")\nfreq = makeconnection(\"inlet\", 1, 110)\ngain = makeconnection(\"inlet\", 2, 0.035)\nstategain = makeconnection(\"inlet\", 5, 1.0)\ntrackgain = makeconnection(\"inlet\", 14, 1.0)\nwave = maketable(\"wave\", 4096, \"sine\", 1, 0.35, 0.12)\nWAVETABLE(0, 3600, gain * 0.80 * stategain * trackgain * 32767.0, 55, 0.45, wave)\nWAVETABLE(0, 3600, gain * 0.26 * stategain * trackgain * 32767.0, 110, 0.55, wave)\nWAVETABLE(0, 3600, gain * 0.14 * stategain * trackgain * 32767.0, 165, 0.60, wave)",
          "processorLanguage": "chuck",
          "processorCode": "",
          "processorEnabled": false,
          "gainEvents": []
        }
      ]
    },
