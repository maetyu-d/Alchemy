+        };
+        weldStream = weldPattern.asStream;
+        weldBeat = 0.0;
+        weldNode = 10000;
+        while { weldBeat < weldLoopBeats } {
+            weldEvent = weldStream.next(Event.default.copy);
+            if (weldEvent.isNil) {
