        {"name": "detuned hoover", "language": "supercollider", "sync": true, "tempo": 210, "timeSigNumerator": 4, "timeSigDenominator": 4, "phase": 0, "gain": 0.42, "muted": false, "soloed": false, "code": "{ |freq = 440, gain = 0.1, blend = 0.5| Splay.ar(Saw.ar(freq * [0.495, 0.5, 0.997, 1.003]) * gain).tanh }", "gainEvents": []},
        {"name": "sync bass", "language": "chuck", "sync": true, "tempo": 210, "timeSigNumerator": 4, "timeSigDenominator": 4, "phase": 0, "gain": 0.50, "muted": false, "soloed": false, "code": "SinOsc b => Gain g => dac;\n[55, 55, 82, 55, 73, 55, 98, 55] @=> int notes[];\n0 => int i;\nwhile (true) {\n    Std.mtof(notes[i % notes.cap()]) => b.freq;\n    0.5 => g.gain;\n    70::ms => now;\n    0 => g.gain;\n    40::ms => now;\n    i++;\n}", "gainEvents": []}
