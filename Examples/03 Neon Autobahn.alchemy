          "code": "// rounded motorik octave bass\nSinOsc sub => Gain subGain => dac;\nSawOsc edge => Gain edgeGain => dac;\n[40, 40, 47, 40, 52, 47, 45, 47, 40, 43, 47, 52, 55, 52, 47, 43] @=> int bass[];\nwhile (true) {\n    Math.floor(hostStateBeat * 2.0) $ int => int step;\n    hostStateBeat * 2.0 - Math.floor(hostStateBeat * 2.0) => float phase;\n    Std.mtof(bass[step % bass.cap()]) => float f;\n    f => sub.freq;\n    f * 2.0 => edge.freq;\n    Math.exp(-phase * 5.4) => float env;\n    Math.max(0.0, Math.min(hostGain, 0.18)) * hostStateGain * hostTrackGain * (0.30 + env * 0.85) => subGain.gain;\n    Math.max(0.0, Math.min(hostGain, 0.055)) * hostStateGain * hostTrackGain * env => edgeGain.gain;\n    1::samp => now;\n}",
