  "chuckScoreScript": "score.clear();\ntempo(132);\nmeter(7, 8);\nphase(0.5);\nstate.add(\"Seven Gate\", 28, 3);\ntrack.add(1, \"SC pulse drums\", \"supercollider\");\ntrack.gain(1, 1, 0.72);\ntrack.add(1, \"seven pulse\", \"chuck\");\ntrack.gain(1, 2, 0.32);\ntrack.add(1, \"phase bell\", \"csound\");\ntrack.gain(1, 3, 0.30);\ntrack.add(1, \"sub orbit\", \"chuck\");\ntrack.gain(1, 4, 0.28);\nstate.add(\"Five Turn\", 20, 5);\ntrack.add(2, \"SC off-grid drums\", \"supercollider\");\ntrack.gain(2, 1, 0.70);\ntrack.add(2, \"five answer\", \"chuck\");\ntrack.gain(2, 2, 0.30);\ntrack.add(2, \"off-grid bass\", \"chuck\");\ntrack.gain(2, 3, 0.30);\ntrack.add(2, \"SC glass cloud\", \"supercollider\");\ntrack.gain(2, 4, 0.26);\nstate.add(\"Eleven Field\", 22, 5);\ntrack.add(3, \"SC eleven drums\", \"supercollider\");\ntrack.gain(3, 1, 0.70);\ntrack.add(3, \"eleven shimmer\", \"supercollider\");\ntrack.gain(3, 2, 0.28);\ntrack.add(3, \"RTcmix low clock\", \"rtcmix\");\ntrack.gain(3, 3, 0.34);\ntrack.add(3, \"needle counter\", \"chuck\");\ntrack.gain(3, 4, 0.26);\nstate.connect(1, 2, 60);\nstate.connect(1, 3, 40);\nstate.connect(2, 1, 25);\nstate.connect(2, 3, 75);\nstate.connect(3, 1, 1);\nplay();",
