          "muted": false,
          "soloed": false,
          "code": "SinOsc b => Gain g => dac;\n[36, 36, 36, 43, 36, 48, 36, 34] @=> int notes[];\n0 => int i;\nwhile (true) {\n    Std.mtof(notes[i % notes.cap()]) => b.freq;\n    0.38 * hostGain * hostStateGain * hostTrackGain => g.gain;\n    58::ms => now;\n    0 => g.gain;\n    (i % 3 == 0 ? 96::ms : 42::ms) => now;\n    i++;\n}",
          "gainEvents": []
        },
        {
          "name": "ChucK siren pin",
          "language": "chuck",
          "sync": true,
          "tempo": 210,
          "timeSigNumerator": 4,
          "timeSigDenominator": 4,
          "phase": 0,
          "gain": 0.22,
          "muted": false,
          "soloed": false,
          "code": "SinOsc s => Gain g => dac;\nwhile (true) {\n    Math.random2f(480, 960) => s.freq;\n    0.12 * hostGain * hostStateGain * hostTrackGain => g.gain;\n    85::ms => now;\n}",
          "gainEvents": []
        }
      ]
    },
    {
